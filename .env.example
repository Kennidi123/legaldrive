# ── Banco de dados ───────────────────────────────────────────
DATABASE_URL=postgresql://USUARIO:SENHA@HOST:5432/legaldrive

# ── Segredos (GERE VALORES FORTES E ÚNICOS — NUNCA reutilize estes) ──
# Gere com:  openssl rand -base64 32   (ou node -e "console.log(crypto.randomBytes(32).toString('base64'))")
# PAYLOAD_SECRET assina os tokens de login do admin. Se for previsível,
# qualquer um pode forjar um token de administrador.
PAYLOAD_SECRET=GERE_UM_VALOR_ALEATORIO_FORTE

# ── URLs públicas ────────────────────────────────────────────
